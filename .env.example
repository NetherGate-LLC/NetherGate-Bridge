# Copy this file to ".env" and fill in real values.

# The port the bridge API listens on.
PORT=3000

# ---- Auth (OPTIONAL) -------------------------------------------------------
# This is meant to run as an open, public service: the MongoDB URI a caller
# sends already contains their credentials, so that IS the access control.
# Leave both of these UNSET for open access.
#
# Only set these if you're self-hosting a PRIVATE instance you want to gate.
# Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Option A — a single shared secret sent as the "x-api-key" header:
# API_KEY=some-long-random-secret
#
# Option B — per-addon keys ("label:secret" pairs, label shows up in logs):
# API_KEYS=survival:secret-one,skyblock:secret-two

# NOTE: the MongoDB connection string and database name are NOT set here.
# Each addon supplies its own (mongoUri + database) in its Bridge() config,
# so one server can serve many addons/databases.

# ---- Optional hardening ----------------------------------------------------

# Comma-separated allowlist of MongoDB hostnames the bridge may connect to.
# Empty => any host allowed. Since addons send the URI, set this in production.
# e.g. ALLOWED_URI_HOSTS=cluster0.abcde.mongodb.net,127.0.0.1
ALLOWED_URI_HOSTS=

# Comma-separated allowlist of collections. Empty => any collection allowed.
ALLOWED_COLLECTIONS=

# Max documents a single query returns / a single write inserts.
MAX_DOCUMENTS=500

# How long (ms) to wait when first connecting to a MongoDB deployment.
CONNECT_TIMEOUT_MS=8000

# Close a cached MongoDB connection after this many ms of inactivity.
IDLE_CLOSE_MS=300000
