{
  "name": "nethergate-bridge",
  "version": "1.0.0",
  "description": "HTTP bridge that lets Minecraft Bedrock (@minecraft/server-net) scripts talk to MongoDB",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongodb": "^6.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "optionalDependencies": {
    "@minecraft/server": "^2.8.0",
    "@minecraft/server-net": "^1.0.0-beta.1.26.32-stable"
  }
}
